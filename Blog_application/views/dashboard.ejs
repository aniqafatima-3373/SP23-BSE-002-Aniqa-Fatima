<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - My Blog</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;600;700&display=swap" rel="stylesheet">
    <style>
        :root { 
            --earth-slate: #7a9ba8; 
            --earth-sage: #87a38d; 
            --bg-overlay: rgba(255, 255, 255, 0.5); 
        }

        body { 
            font-family: 'Montserrat', sans-serif; 
            margin: 0; 
            background: linear-gradient(var(--bg-overlay), var(--bg-overlay)), 
                        url('/background.jpg');
            background-size: cover; 
            background-position: center; 
            background-attachment: fixed;
            color: #333;
        }

        .navbar {
            background: rgba(255, 255, 255, 0.9);
            padding: 15px 5%;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: 0 2px 15px rgba(0,0,0,0.05);
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        .navbar h1 { 
            margin: 0; 
            font-size: 1.3rem; 
            color: var(--earth-slate); 
            letter-spacing: 2px;
            text-transform: uppercase;
        }

        .container {
            margin: 40px 0;
            padding-left: 5%; 
        }

        .post-card {
            background: white;
            border-radius: 25px;
            padding: 40px;
            margin-bottom: 35px;
            box-shadow: 0 15px 45px rgba(0,0,0,0.08);
            /* INCREASED SIZE: Now 1000px for a larger display area */
            width: 90%;
            max-width: 1000px; 
            border: 1px solid rgba(122, 155, 168, 0.1);
            animation: slideIn 0.8s ease-out;
        }

        @keyframes slideIn {
            from { opacity: 0; transform: translateX(-30px); }
            to { opacity: 1; transform: translateX(0); }
        }

        .author-info {
            font-size: 0.8rem;
            color: var(--earth-slate);
            font-weight: 600;
            margin-bottom: 20px;
            display: block;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .post-card h2 { font-size: 2rem; margin-top: 0; color: #444; }

        /* Small image as requested */
        .post-image {
            width: 180px; 
            height: 120px; 
            object-fit: cover;
            border-radius: 12px;
            margin: 20px 0;
            display: block;
            border: 1px solid #eee;
        }

        .post-content {
            font-size: 1.05rem;
            line-height: 1.8;
            color: #555;
            margin-bottom: 30px;
        }

        .btn {
            padding: 10px 22px;
            text-decoration: none;
            border-radius: 8px;
            font-weight: 600;
            font-size: 0.8rem;
            text-transform: uppercase;
            display: inline-block;
            transition: 0.3s;
        }

        .btn-new { background: var(--earth-slate); color: white; border: none; }
        .btn-edit { background: #f7f7f7; color: var(--earth-slate); margin-right: 10px; }
        .btn-delete { background: transparent; color: #b35a44; border: 1px solid #eee; cursor: pointer; }
        .logout { color: #b35a44; text-decoration: none; font-weight: 600; font-size: 0.9rem; }

        .btn:hover { opacity: 0.8; transform: translateY(-2px); }
    </style>
</head>
<body>

    <nav class="navbar">
        <h1>UniBlog</h1>
        <div>
            <a href="/post/new" class="btn btn-new">New Post</a>
            <a href="/logout" class="logout" style="margin-left: 20px;">Logout</a>
        </div>
    </nav>

    <div class="container">
        <% if (posts.length > 0) { %>
            <% posts.forEach(function(post) { %>
                <div class="post-card">
                    <span class="author-info">
                        By <%= post.author.username %> • <%= post.createdAt.toDateString() %>
                    </span>
                    
                    <h2><%= post.title %></h2>

                    <% if (post.image) { %>
                        <img src="/uploads/<%= post.image %>" class="post-image" alt="Blog Image">
                    <% } %>

                    <div class="post-content">
                        <%- post.content %>
                    </div>

                    <div class="actions">
                        <a href="/post/edit/<%= post._id %>" class="btn btn-edit">Edit</a>
                        <form action="/post/delete/<%= post._id %>" method="POST" style="display:inline;">
                            <button type="submit" class="btn btn-delete" onclick="return confirm('Delete this post?')">Delete</button>
                        </form>
                    </div>
                </div>
            <% }); %>
        <% } else { %>
            <div class="post-card">
                <p>No posts found. Start writing!</p>
            </div>
        <% } %>
    </div>

</body>
</html>