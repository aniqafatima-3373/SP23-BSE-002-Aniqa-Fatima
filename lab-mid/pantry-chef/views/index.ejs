<!DOCTYPE html>
<html>
<head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <title>Pantry Chef</title>
</head>
<body style="background-color: #fff0f5;"> <div class="container mt-5">
        <h1 class="text-center" style="color: #d63384;">Pantry Chef</h1>
        <p class="text-center">Enter the ingredients you have to find a recipe!</p>
        <form action="/search" method="GET" class="mt-4">
            <div class="input-group mb-3">
                <input type="text" name="items" class="form-control" placeholder="e.g. egg, milk, onion" required>
                <button class="btn btn-danger" type="submit">Search Recipes</button>
            </div>
        </form>
    </div>
</body>
</html>