<!DOCTYPE html>
<html>
<head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        /* --- Aapka Existing Style --- */
        .splash-bg {
            background: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.6)), url('https://images.unsplash.com/photo-1473093226795-af9932fe5856?w=1600');
            background-size: cover; 
            background-position: center; 
            height: 100vh;
            display: flex; 
            align-items: center; 
            justify-content: center; 
            color: white;
            flex-direction: column;
        }
        .btn-olive { 
            background-color: #556B2F; 
            color: white; 
            padding: 12px 30px; 
            border-radius: 30px; 
            border: none; 
            font-weight: bold; 
            text-decoration: none;
            display: inline-block;
        }
        .btn-olive:hover { background-color: #3e4e22; color: white; }

        /* --- New Scrolling & Info Styles --- */
        html {
            scroll-behavior: smooth;
        }
        .info-section {
            background-color: #fdfae6; /* Cream background */
            padding: 80px 0;
            color: #3e4e22; /* Olive text */
        }
        .feature-card {
            background: white;
            border-radius: 20px;
            padding: 30px;
            box-shadow: 0 10px 30px rgba(62, 78, 34, 0.1);
            transition: 0.3s;
            border: 1px solid #e9e6ca;
        }
        .feature-card:hover {
            transform: translateY(-10px);
        }
        .scroll-indicator {
            position: absolute;
            bottom: 30px;
            animation: bounce 2s infinite;
            color: white;
            text-decoration: none;
            font-size: 0.9rem;
        }
        @keyframes bounce {
            0%, 20%, 50%, 80%, 100% {transform: translateY(0);}
            40% {transform: translateY(-10px);}
            60% {transform: translateY(-5px);}
        }
    </style>
</head>
<body>

    <div class="splash-bg text-center">
        <div>
            <h1 class="display-1 fw-bold mb-3" style="font-family: 'Serif';">Pantry Chef</h1>
            <p class="lead mb-4">Transforming modest ingredients into curated culinary experiences.</p>
            <a href="/signup" class="btn btn-olive">Continue to Kitchen →</a>
        </div>
        <a href="#about" class="scroll-indicator">
            Explore Features <br> ▽
        </a>
    </div>

    <section id="about" class="info-section">
        <div class="container text-center">
            <h2 class="display-5 fw-bold mb-5">Why Pantry Chef?</h2>
            
            <div class="row g-4">
                <div class="col-md-4">
                    <div class="feature-card h-100">
                        <div class="display-4 mb-3">🌍</div>
                        <h4 class="fw-bold">Hybrid Search</h4>
                        <p class="text-muted">Search through millions of global recipes while managing your personal local database in one place.</p>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="feature-card h-100">
                        <div class="display-4 mb-3">⚖️</div>
                        <h4 class="fw-bold">Portion Scaler</h4>
                        <p class="text-muted">Adjust ingredients instantly for any number of servings without manual math or re-calculations.</p>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="feature-card h-100">
                        <div class="display-4 mb-3">🥑</div>
                        <h4 class="fw-bold">Substitution Engine</h4>
                        <p class="text-muted">Missing an ingredient? Our smart engine provides the best alternatives to keep your cooking seamless.</p>
                    </div>
                </div>
            </div>

            <div class="mt-5 pt-5">
                <hr style="border-color: #556B2F; opacity: 0.2;">
                <p class="small text-muted mt-4">© 2026 Pantry Chef - Built for Modern Cooks</p>
                <a href="/dashboard" class="text-decoration-none fw-bold" style="color: #556B2F;">Back to Dashboard</a>
            </div>
        </div>
    </section>

</body>
</html>