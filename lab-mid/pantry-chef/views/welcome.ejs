<!DOCTYPE html>
<html>
<head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        .splash-bg {
            background: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.6)), url('https://images.unsplash.com/photo-1473093226795-af9932fe5856?w=1600');
            background-size: cover; background-position: center; height: 100vh;
            display: flex; align-items: center; justify-content: center; color: white;
        }
        .btn-olive { background-color: #556B2F; color: white; padding: 12px 30px; border-radius: 30px; border: none; font-weight: bold; }
        .btn-olive:hover { background-color: #3e4e22; color: white; }
    </style>
</head>
<body>
    <div class="splash-bg text-center">
        <div>
            <h1 class="display-1 fw-bold mb-3" style="font-family: 'Serif';">Pantry Chef</h1>
            <p class="lead mb-4">Transforming modest ingredients into curated culinary experiences.</p>
            <a href="/dashboard" class="btn btn-olive">Continue to Kitchen →</a>
        </div>
    </div>
</body>
</html>