<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Results | Pantry Chef</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        :root { --olive: #556B2F; --cream: #fdfae6; --dark: #2c331f; --text: #3e4e22; }
        body { background-color: var(--cream); color: var(--text); font-family: 'Segoe UI', sans-serif; transition: 0.3s; }
        .sidebar { width: 260px; height: 100vh; position: fixed; background: #f7f3d7; border-right: 1px solid #e9e6ca; padding: 25px; z-index: 1000; }
        .nav-link { color: var(--text); font-weight: 600; margin-bottom: 12px; border-radius: 12px; padding: 12px 15px; transition: 0.3s; cursor: pointer; border: none; background: transparent; display: block; text-decoration: none; width: 100%; text-align: left; }
        .nav-link:hover, .nav-link.active { background: var(--olive); color: white !important; }
        .main-content { margin-left: 260px; padding: 40px; min-height: 100vh; }
        .recipe-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 25px; margin-top: 30px; }
        .recipe-card { background: white; border-radius: 20px; overflow: hidden; border: 1px solid #e9e6ca; transition: 0.3s; text-decoration: none; color: inherit; display: block; }
        .recipe-card:hover { transform: translateY(-8px); box-shadow: 0 12px 24px rgba(62,78,34,0.12); }
        .recipe-img { width: 100%; height: 180px; object-fit: cover; }
        .ingredient-badge { background: #e9e6ca; color: var(--olive); padding: 5px 12px; border-radius: 20px; font-size: 12px; margin-right: 5px; font-weight: bold; }
        .modal-content-custom { background-color: var(--cream); border: 2px solid var(--olive); border-radius: 25px; }
        body.dark-mode { background-color: var(--dark); color: #fdfae6; }
        body.dark-mode .sidebar { background: #323a24; border-color: #444; }
        body.dark-mode .recipe-card { background: #3a422d; border-color: #556B2F; color: white; }
    </style>
</head>
<body>

    <div class="sidebar d-flex flex-column justify-content-between">
        <div>
            <h3 class="fw-bold mb-5" style="color: var(--olive);">Pantry Chef</h3>
            <nav>
                <a href="/dashboard" class="nav-link"><i class="bi bi-house-door me-2"></i> HOME</a>
                <button class="nav-link active" data-bs-toggle="modal" data-bs-target="#searchModal"><i class="bi bi-search me-2"></i> SEARCH</button>
                <button class="nav-link" onclick="toggleDarkMode()"><i id="theme-icon" class="bi bi-moon-stars me-2"></i> NIGHT MODE</button>
            </nav>
        </div>
        <div class="d-flex align-items-center p-3 border-top border-secondary border-opacity-25">
            <img src="https://ui-avatars.com/api/?name=<%= user.username %>&background=556B2F&color=fff" class="rounded-circle me-3" width="45">
            <div>
                <p class="m-0 fw-bold small text-uppercase"><%= user.username %></p>
                <p class="m-0 text-muted" style="font-size: 11px;">CHEF DE PARTIE</p>
                <a href="/logout" class="text-danger fw-bold" style="font-size: 10px; text-decoration: none;">SIGN OUT</a>
            </div>
        </div>
    </div>

    <div class="main-content">
        <header class="mb-4">
            <h2 class="fw-bold">Search Results</h2>
            <p class="text-muted">Showing results for: 
                <% items.forEach(item => { %>
                    <span class="ingredient-badge"><%= item %></span>
                <% }) %>
            </p>
        </header>

        <div class="recipe-grid">
            <% recipes.forEach(recipe => { %>
                <a href="/recipe/<%= recipe._id || recipe.id %>" class="recipe-card">
                    <img src="<%= recipe.imageUrl || recipe.image %>" class="recipe-img" onerror="this.src='https://via.placeholder.com/300x200?text=Food'">
                    <div class="p-3">
                        <h5 class="fw-bold mb-1"><%= recipe.title %></h5>
                        <p class="small text-muted">Click to view detail</p>
                    </div>
                </a>
            <% }) %>
        </div>
    </div>

    <div class="modal fade" id="searchModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content modal-content-custom p-4 text-center">
                <h3 class="fw-bold mb-3" style="color: var(--olive);">Refine Search</h3>
                <form action="/search" method="GET">
                    <input type="text" name="items" class="form-control mb-3 text-center" placeholder="Ingredients..." required style="border-radius: 12px; border: 1px solid var(--olive);">
                    <button type="submit" class="btn btn-dark w-100 rounded-pill py-2" style="background: var(--olive);">Search Again →</button>
                </form>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function toggleDarkMode() {
            const body = document.body;
            body.classList.toggle('dark-mode');
            localStorage.setItem('theme', body.classList.contains('dark-mode') ? 'dark' : 'light');
        }
        if (localStorage.getItem('theme') === 'dark') document.body.classList.add('dark-mode');
    </script>
</body>
</html>