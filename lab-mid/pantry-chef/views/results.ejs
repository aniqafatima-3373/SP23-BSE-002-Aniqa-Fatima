<!DOCTYPE html>
<html>
<head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background-color: #fdfae6; color: #3e4e22; font-family: 'Georgia', serif; }
        .result-header { color: #556B2F; border-bottom: 2px solid #556B2F; padding-bottom: 10px; }
        .recipe-card { background-color: #fff; border: none; border-radius: 12px; overflow: hidden; transition: 0.3s; }
        .recipe-card:hover { transform: translateY(-10px); box-shadow: 0 10px 20px rgba(85, 107, 47, 0.2); }
        .card-img-top { height: 200px; object-fit: cover; }
        .btn-olive { background-color: #556B2F; color: white; border-radius: 5px; font-size: 0.9rem; }
        .badge-source { background-color: #e9e6ca; color: #556B2F; font-size: 0.7rem; border: 1px solid #556B2F; }
    </style>
</head>
<body class="container py-5">
    <div class="mb-5 text-start">
        <h6 class="text-uppercase text-muted small letter-spacing">Curated Findings</h6>
        <h1 class="result-header">Search Results: '<%= items.join(', ') %>'</h1>
    </div>

    <div class="row">
        <% recipes.forEach(recipe => { %>
            <div class="col-md-4 mb-4">
                <div class="recipe-card shadow-sm h-100">
                    <img src="<%= recipe.image || recipe.imageUrl %>" class="card-img-top" alt="food">
                    <div class="p-3">
                        <span class="badge badge-source mb-2"><%= recipe.id ? 'GLOBAL' : 'CHEF SPECIAL' %></span>
                        <h5 class="fw-bold"><%= recipe.title %></h5>
                        <p class="text-muted small mb-3">
                            <%= Array.isArray(recipe.ingredients) ? recipe.ingredients.slice(0, 3).join(', ') + '...' : 'Instructions included' %>
                        </p>
                        <a href="/recipe/<%= recipe.id || recipe._id %>" class="btn btn-olive w-100">View Full Recipe</a>
                    </div>
                </div>
            </div>
        <% }) %>
    </div>
    
    <div class="text-center mt-5">
        <a href="/dashboard" class="btn btn-outline-secondary px-5" style="border-radius: 20px;">Return to Kitchen</a>
    </div>
</body>
</html>