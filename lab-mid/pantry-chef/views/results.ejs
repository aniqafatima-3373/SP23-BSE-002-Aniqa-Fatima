<!DOCTYPE html>
<html>
<head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        /* --- CSS Variables for Night Mode --- */
        :root {
            --bg-color: #fdfae6;
            --text-color: #3e4e22;
            --card-bg: #ffffff;
            --header-border: #556B2F;
            --card-shadow: rgba(85, 107, 47, 0.2);
            --badge-bg: #e9e6ca;
        }

        [data-theme="dark"] {
            --bg-color: #1a1d13;
            --text-color: #fdfae6;
            --card-bg: #2d3a1a;
            --header-border: #a3b18a;
            --card-shadow: rgba(0, 0, 0, 0.5);
            --badge-bg: #3e4e22;
        }

        body { 
            background-color: var(--bg-color); 
            color: var(--text-color); 
            font-family: 'Georgia', serif; 
            transition: 0.3s ease; 
        }

        .result-header { 
            color: var(--header-border); 
            border-bottom: 2px solid var(--header-border); 
            padding-bottom: 10px; 
        }

        .recipe-card { 
            background-color: var(--card-bg); 
            border: none; 
            border-radius: 12px; 
            overflow: hidden; 
            transition: 0.3s; 
            color: var(--text-color);
        }

        .recipe-card:hover { 
            transform: translateY(-10px); 
            box-shadow: 0 10px 20px var(--card-shadow); 
        }

        .card-img-top { height: 200px; object-fit: cover; }

        .btn-olive { 
            background-color: #556B2F; 
            color: white; 
            border-radius: 5px; 
            font-size: 0.9rem; 
            border: none;
        }
        .btn-olive:hover { background-color: #3e4e22; color: #fdfae6; }

        .badge-source { 
            background-color: var(--badge-bg); 
            color: var(--text-color); 
            font-size: 0.7rem; 
            border: 1px solid var(--header-border); 
        }

        .no-print-btn { border-radius: 20px; }
    </style>
</head>
<body class="container py-5">
    
    <div class="d-flex justify-content-between align-items-center mb-4">
        <a href="/dashboard" class="text-decoration-none" style="color: var(--header-border)">← Back to Dashboard</a>
        <button class="btn btn-sm btn-outline-success no-print-btn" onclick="toggleTheme()" id="themeBtn">🌙 Night Mode</button>
    </div>

    <div class="mb-5 text-start">
        <h6 class="text-uppercase text-muted small letter-spacing">Curated Findings</h6>
        <h1 class="result-header">Search Results: '<%= items.join(', ') %>'</h1>
    </div>

    <div class="row">
        <% if (recipes.length > 0) { %>
            <% recipes.forEach(recipe => { %>
                <div class="col-md-4 mb-4">
                    <div class="recipe-card shadow-sm h-100">
                        <img src="<%= recipe.image || recipe.imageUrl %>" class="card-img-top" alt="food">
                        <div class="p-3">
                            <span class="badge badge-source mb-2"><%= recipe.id ? 'GLOBAL' : 'CHEF SPECIAL' %></span>
                            <h5 class="fw-bold"><%= recipe.title %></h5>
                            <p class="text-muted small mb-3">
                                <%= Array.isArray(recipe.ingredients) ? recipe.ingredients.slice(0, 3).join(', ') + '...' : 'Instructions included' %>
                            </p>
                            <a href="/recipe/<%= recipe.id || recipe._id %>" class="btn btn-olive w-100">View Full Recipe</a>
                        </div>
                    </div>
                </div>
            <% }) %>
        <% } else { %>
            <div class="col-12 text-center py-5">
                <h3>No recipes found for these ingredients.</h3>
                <p>Try searching for something else!</p>
            </div>
        <% } %>
    </div>
    
    <div class="text-center mt-5">
        <a href="/dashboard" class="btn btn-outline-secondary px-5 no-print-btn">Return to Kitchen</a>
    </div>

    <script>
        // --- Shared Theme Logic ---
        function applyTheme() {
            const savedTheme = localStorage.getItem('theme') || 'light';
            document.documentElement.setAttribute('data-theme', savedTheme);
            const btn = document.getElementById('themeBtn');
            if(btn) btn.innerHTML = savedTheme === 'dark' ? '☀️ Day Mode' : '🌙 Night Mode';
        }

        function toggleTheme() {
            const current = document.documentElement.getAttribute('data-theme');
            const next = current === 'dark' ? 'light' : 'dark';
            document.documentElement.setAttribute('data-theme', next);
            localStorage.setItem('theme', next);
            const btn = document.getElementById('themeBtn');
            if(btn) btn.innerHTML = next === 'dark' ? '☀️ Day Mode' : '🌙 Night Mode';
        }

        // Initialize theme on load
        applyTheme();
    </script>
</body>
</html>