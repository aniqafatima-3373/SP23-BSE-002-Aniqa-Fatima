<!DOCTYPE html>
<html lang="en">
<head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        /* --- Sidebar & Layout Styling --- */
        :root { 
            --olive: #556B2F; 
            --cream: #fdfae6; 
            --bg-color: #fdfae6;
            --text-color: #1a1a1a;
            --card-bg: #e9e6ca;
            --heading-color: #3e4e22;
            --accent-color: #556B2F;
        }

        [data-theme="dark"] {
            --bg-color: #1a1d13;
            --text-color: #fdfae6;
            --card-bg: #2d3a1a;
            --heading-color: #a3b18a;
            --accent-color: #8fa37a;
        }

        body { background-color: var(--bg-color); color: var(--text-color); transition: 0.3s; line-height: 1.6; margin: 0; }
        
        /* Sidebar Styles (Consistent with Dashboard) */
        .sidebar { 
            width: 260px; height: 100vh; position: fixed; 
            background: #f7f3d7; border-right: 1px solid var(--card-bg); 
            padding: 25px; z-index: 1000; 
        }
        .nav-link { 
            color: var(--text-color); font-weight: 600; margin-bottom: 12px; 
            border-radius: 12px; padding: 12px 15px; transition: 0.3s; 
            cursor: pointer; border: none; background: transparent; 
            display: block; text-decoration: none; width: 100%; text-align: left; 
        }
        .nav-link:hover, .nav-link.active { background: var(--olive); color: white !important; }
        
        /* Main Content Adjustment */
        .main-wrapper { margin-left: 260px; padding: 50px; width: calc(100% - 260px); }

        /* --- Your Original Styling --- */
        .main-img { border-radius: 20px; box-shadow: 15px 15px 0px var(--card-bg); width: 100%; object-fit: cover; height: 500px; }
        .section-title { border-left: 4px solid var(--accent-color); padding-left: 15px; color: var(--accent-color); font-weight: bold; }
        .stats-box { background-color: var(--card-bg); border-radius: 15px; padding: 20px; color: var(--accent-color); }
        .sub-box { border: 2px dashed var(--accent-color); border-radius: 15px; padding: 15px; background-color: rgba(255,255,255,0.05); }
        .btn-olive { background-color: var(--heading-color); color: white; border-radius: 30px; border: none; padding: 10px 25px; transition: 0.3s; }
        .btn-download { border: 2px solid var(--accent-color); color: var(--accent-color); border-radius: 30px; padding: 10px 30px; font-weight: bold; background: transparent; }

        @media print {
            .sidebar, .no-print, .btn, .sub-box { display: none !important; }
            .main-wrapper { margin-left: 0 !important; width: 100% !important; padding: 20px !important; }
        }

        /* Dark Mode Sidebar Adjustment */
        [data-theme="dark"] .sidebar { background: #323a24; border-color: #444; }
    </style>
</head>
<body>

    <div class="sidebar d-flex flex-column justify-content-between no-print">
        <div>
            <h3 class="fw-bold mb-5" style="color: var(--olive);">Pantry Chef</h3>
            <nav>
                <a href="/dashboard" class="nav-link"><i class="bi bi-house-door me-2"></i> HOME</a>
                <button class="nav-link" data-bs-toggle="modal" data-bs-target="#searchModal"><i class="bi bi-search me-2"></i> SEARCH</button>
                <button class="nav-link" onclick="toggleTheme()" id="themeBtnNav"><i class="bi bi-moon-stars me-2"></i> NIGHT MODE</button>
            </nav>
        </div>

        <div class="d-flex align-items-center p-3 border-top border-secondary border-opacity-25">
            <img src="https://ui-avatars.com/api/?name=<%= user.username %>&background=556B2F&color=fff" class="rounded-circle me-3" width="45">
            <div>
                <p class="m-0 fw-bold small text-uppercase"><%= user.username %></p>
                <p class="m-0 text-muted" style="font-size: 11px;">CHEF DE PARTIE</p>
                <a href="/logout" class="text-danger fw-bold" style="font-size: 10px; text-decoration: none;">SIGN OUT</a>
            </div>
        </div>
    </div>

    <div class="main-wrapper">
        <div class="mb-4 no-print">
            <a href="javascript:history.back()" class="btn btn-outline-secondary px-4" style="border-radius: 30px;">← Back</a>
            </div>

        <div class="row align-items-start" id="recipeArea">
            <div class="col-md-5">
                <img src="<%= recipe.image || recipe.imageUrl %>" class="main-img mb-4">
                
                <div class="stats-box d-flex justify-content-between text-center mt-4">
                    <div><small>PREP TIME</small><br><strong><%= recipe.prepTime || recipe.readyInMinutes || 20 %>m</strong></div>
                    <div>
                        <small>SERVES</small><br>
                        <input type="number" id="servings" value="4" min="1" max="20" 
                               class="form-control form-control-sm text-center fw-bold" 
                               style="width: 60px; margin: 0 auto; background: transparent; color: inherit; border: 1px solid var(--accent-color);" 
                               onchange="scaleIngredients()">
                    </div>
                    <div><small>DIFFICULTY</small><br><strong>Beginner</strong></div>
                </div>

                <div class="sub-box mt-4 no-print">
                    <h6 class="fw-bold mb-2">🥬 Ingredient Missing?</h6>
                    <div class="input-group input-group-sm mb-2">
                        <input type="text" id="subInput" class="form-control" 
                               placeholder="Type ingredient..." 
                               style="background-color: var(--bg-color); color: var(--text-color); border: 1px solid var(--accent-color);">
                        <button class="btn btn-olive" type="button" onclick="searchSubstitute()">Find</button>
                    </div>
                    <p id="subResult" class="small mb-0 mt-2 text-italic" style="min-height: 20px;"></p>
                </div>
            </div>

            <div class="col-md-7 ps-md-5">
                <h6 class="text-uppercase text-muted small">The Apothecary Pantry</h6>
                <h1 class="display-4 fw-bold mb-4" style="color: var(--heading-color);"><%= recipe.title %></h1>
                
                <h4 class="section-title mt-5 mb-3">Ingredients List</h4>
                <ul class="list-unstyled" id="ingredientsList">
                    <% if(recipe.extendedIngredients) { %>
                        <% recipe.extendedIngredients.forEach(ing => { %>
                            <li class="py-1 border-bottom border-light ingredient-item" data-base-qty="<%= ing.amount %>">
                                ✔ <span class="qty"><%= ing.amount %></span> <%= ing.unit %> <%= ing.name %>
                            </li>
                        <% }) %>
                    <% } else if (Array.isArray(recipe.ingredients)) { %>
                         <% recipe.ingredients.forEach(ing => { %>
                            <li class="py-1 border-bottom border-light">✔ <%= ing %></li>
                        <% }) %>
                    <% } %>
                </ul>

                <h4 class="section-title mt-5 mb-3">Culinary Protocol</h4>
                <div class="instruction-steps">
                    <div class="lead"><%- recipe.instructions || recipe.summary %></div>
                </div>

                <div class="mt-5 d-flex gap-3 no-print">
                    <button class="btn btn-download" onclick="exportToPDF()">📥 Export PDF Card</button>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="searchModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" style="background-color: var(--bg-color); border: 2px solid var(--accent-color); border-radius: 25px;">
                <div class="modal-body p-5 text-center">
                    <h4 class="fw-bold mb-4" style="color: var(--accent-color);">Quick Search</h4>
                    <form action="/search" method="GET">
                        <input type="text" name="items" class="form-control text-center mb-3" placeholder="Tomato, Garlic..." required style="border-radius: 12px; border: 1px solid var(--accent-color); background: transparent; color: inherit;">
                        <button type="submit" class="btn btn-olive w-100 rounded-pill py-2 fw-bold">Search →</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function applyTheme() {
            const savedTheme = localStorage.getItem('theme') || 'light';
            document.documentElement.setAttribute('data-theme', savedTheme);
            const btnText = savedTheme === 'dark' ? '☀️ Day Mode' : '🌙 Night Mode';
            if(document.getElementById('themeBtnNav')) {
                document.getElementById('themeBtnNav').innerHTML = `<i class="bi bi-${savedTheme === 'dark' ? 'sun' : 'moon-stars'} me-2"></i> ${btnText}`;
            }
        }

        function toggleTheme() {
            const current = document.documentElement.getAttribute('data-theme');
            const next = current === 'dark' ? 'light' : 'dark';
            document.documentElement.setAttribute('data-theme', next);
            localStorage.setItem('theme', next);
            applyTheme();
        }

        function scaleIngredients() {
            const servings = document.getElementById('servings').value;
            const factor = servings / 4; 
            const qtyElements = document.querySelectorAll('.qty');
            qtyElements.forEach(el => {
                const base = el.parentElement.getAttribute('data-base-qty');
                if (base) { el.innerText = (base * factor).toFixed(2); }
            });
        }

        const substitutes = {
            "egg": "1/4 cup Applesauce or 1/4 cup Yogurt",
            "butter": "Ghee, Margarine or Vegetable Oil",
            "milk": "Almond milk, Soy milk or 1/2 cup Evaporated milk",
            "lemon": "1/2 tsp Vinegar or 1/4 tsp Amchur Powder",
            "ginger": "1/4 tsp Ground Ginger for 1 tsp fresh grated",
            "garlic": "1/8 tsp Garlic Powder for 1 fresh clove",
            "cornstarch": "2 tbsp Maida for 1 tbsp Cornstarch",
            "tomato": "1/2 cup Tomato Sauce or 1/2 cup Yogurt"
        };

        function searchSubstitute() {
            const input = document.getElementById('subInput').value.toLowerCase().trim();
            const res = document.getElementById('subResult');
            if (!input) { res.innerHTML = "Please type an ingredient first!"; return; }
            if (substitutes[input]) {
                res.innerHTML = `<span class="fw-bold" style="color: var(--accent-color)">Try this:</span> ${substitutes[input]}`;
            } else {
                res.innerHTML = `<span class="text-danger">No substitute found for "${input}".</span>`;
            }
        }

        function exportToPDF() { window.print(); }
        applyTheme();
    </script>
</body>
</html>