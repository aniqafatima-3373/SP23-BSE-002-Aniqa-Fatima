<!DOCTYPE html>
<html>
<head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        .auth-bg {
            /* Splash screen wala hi background use kiya hai */
            background: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.7)), url('https://images.unsplash.com/photo-1473093226795-af9932fe5856?w=1600');
            background-size: cover; background-position: center; 
            height: 100vh; display: flex; align-items: center; justify-content: center;
        }
        .auth-card {
            background: rgba(253, 250, 230, 0.95); /* Cream color with slight transparency */
            padding: 40px; border-radius: 25px; width: 100%; max-width: 400px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.3);
            color: #3e4e22;
        }
        .btn-olive { background-color: #556B2F; color: white; border-radius: 30px; font-weight: bold; border: none; padding: 10px; }
        .btn-olive:hover { background-color: #3e4e22; color: white; }
        .form-control { border-radius: 15px; border: 1px solid #e9e6ca; padding: 12px; }
    </style>
</head>
<body>
    <div class="auth-bg">
        <div class="auth-card text-center">
            <h2 class="fw-bold mb-4">Create Account</h2>
            <form action="/signup" method="POST">
                <div class="mb-3 text-start">
                    <label class="small fw-bold">USERNAME</label>
                    <input type="text" name="username" class="form-control" placeholder="Choose a username" required>
                </div>
                <div class="mb-3 text-start">
                    <label class="small fw-bold">EMAIL ADDRESS</label>
                    <input type="email" name="email" class="form-control" placeholder="Enter your email" required>
                </div>
                <div class="mb-4 text-start">
                    <label class="small fw-bold">PASSWORD</label>
                    <input type="password" name="password" class="form-control" placeholder="Create a password" required>
                </div>
                <button type="submit" class="btn btn-olive w-100 mb-3">Sign Up →</button>
                <p class="small text-muted">Already have an account? <a href="/login" class="text-decoration-none fw-bold" style="color: #556B2F;">Login</a></p>
            </form>
        </div>
    </div>
</body>
</html>